rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isUser(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Each user can only read/write their own profile document.
    match /users/{userId} {
      allow read, write: if isUser(userId);

      // Study sessions are private to the owning user.
      match /studySessions/{sessionId} {
        allow read, write: if isUser(userId);
      }

      // Per-card Skip / Review marks are private to the owning user.
      match /cardMarks/{cardId} {
        allow read, write: if isUser(userId);
      }

      // Per-field question results (last 5 success/fail/unseen) are private to the owning user.
      match /questionResults/{resultId} {
        allow read, write: if isUser(userId);
      }
    }

    // setCards join documents are private to the owning user.
    // Reads are also allowed when the parent set is public so that the clone
    // operation can enumerate cards from another user's market set.
    match /setCards/{linkId} {
      allow read: if isAuth() && (
          resource.data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/sets/$(resource.data.setId)).data.isPublic == true
      );
      allow update, delete: if isAuth() &&
          resource.data.userId == request.auth.uid;
      allow create: if isAuth() &&
          request.resource.data.userId == request.auth.uid;
    }

    // Cards are readable by any authenticated user — card IDs are not
    // guessable and future sharing / marketplace features require that a
    // user who has legitimately obtained a card ID (e.g. from a shared set)
    // can read it.  Write operations remain restricted to the creator.
    match /cards/{cardId} {
      allow read: if isAuth();
      allow update, delete: if isAuth() &&
          resource.data.get('createdBy', request.auth.uid) == request.auth.uid;
      allow create: if isAuth() &&
          request.resource.data.createdBy == request.auth.uid;
    }

    // Card sets are owned by their creator but public sets are readable by
    // any authenticated user so they can be browsed in the Market tab.
    match /sets/{setId} {
      allow read: if isAuth() && (
          resource.data.userId == request.auth.uid ||
          resource.data.isPublic == true);
      allow update, delete: if isAuth() &&
          resource.data.userId == request.auth.uid;
      allow create: if isAuth() &&
          request.resource.data.userId == request.auth.uid;
    }

    // Acquisition records link a market set to a user's acquired copy.
    // Any authenticated user may create a record for themselves.
    // Reads are restricted to the acquirer and the original creator.
    // Records are immutable after creation (no update).
    // Deletion is allowed by the acquirer (needed for future subscription cancellation).
    match /setAcquisitions/{acquisitionId} {
      allow create: if isAuth() &&
          request.resource.data.acquiredByUserId == request.auth.uid;
      allow read: if isAuth() && (
          resource.data.acquiredByUserId == request.auth.uid ||
          resource.data.originalUserId == request.auth.uid);
      allow delete: if isAuth() &&
          resource.data.acquiredByUserId == request.auth.uid;
      allow update: if false;
    }

    // Templates are private to the user who created them.
    match /templates/{templateId} {
      allow read, update, delete: if isAuth() &&
          resource.data.createdBy == request.auth.uid;
      allow create: if isAuth() &&
          request.resource.data.createdBy == request.auth.uid;
    }

    // Question templates are private to the user who created them.
    match /questionTemplates/{templateId} {
      allow read, update, delete: if isAuth() &&
          resource.data.createdBy == request.auth.uid;
      allow create: if isAuth() &&
          request.resource.data.createdBy == request.auth.uid;
    }

    // Tags are global — any authenticated user can read (needed for autocomplete
    // across accounts and for future marketplace discovery).
    // Only the coining user can create; usageCount is the only mutable field
    // after creation; hard deletion by clients is never permitted.
    match /tags/{normalizedName} {
      allow read: if isAuth();
      allow create: if isAuth()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.usageCount == 1;
      // displayName, createdBy, and normalizedName are immutable after creation.
      allow update: if isAuth()
          && request.resource.data.displayName == resource.data.displayName
          && request.resource.data.createdBy  == resource.data.createdBy
          && request.resource.data.normalizedName == resource.data.normalizedName;
      allow delete: if false;
    }

    // Workbook cards follow the same read policy as flash cards above.
    match /workbookCards/{cardId} {
      allow read: if isAuth();
      allow update, delete: if isAuth() &&
          resource.data.get('createdBy', request.auth.uid) == request.auth.uid;
      allow create: if isAuth() &&
          request.resource.data.createdBy == request.auth.uid;
    }
  }
}
