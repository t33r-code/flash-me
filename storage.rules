rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // All user-owned media files.
    // Path: users/{userId}/... (any depth)
    //
    // Reads are open to any authenticated user — card IDs are not guessable,
    // and shared/marketplace content must be readable by other users.
    // Writes (create, update, delete) are restricted to the owning user only.
    match /users/{userId}/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

  }
}